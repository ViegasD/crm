# App
SECRET_KEY=change-me-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://crm:crm@postgres:5432/crm

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Encryption key for channel credentials (AES-256 — base64-encoded 32 bytes)
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Evolution API
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=evolution-secret-key

# LiteLLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Encryption key for credentials (AES-256, base64-encoded 32 bytes)
CREDENTIAL_ENCRYPTION_KEY=changeme32bytesbase64encodedhere=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
